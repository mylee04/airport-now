{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "bunVersion": "1.3.1",
  "installCommand": "bun install",
  "buildCommand": "bun run build:web",
  "outputDirectory": "web/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/router?pathname=/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/api/router?pathname=/uploads/$1"
    }
  ]
}
